# Database Configuration
DATABASE_URL=

# Server Configuration
PORT=
NODE_ENV=

# CORS
FRONTEND_URL=
CORS_ORIGINS=

# API URL for frontend (Vite)
VITE_API_URL=

# Authentication
AUTH_TOKEN_SECRET=

# Google OAuth (for Google My Business integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Meta/Facebook OAuth (for Facebook & Instagram integration)
# Você precisa criar um app em https://developers.facebook.com/apps/
META_APP_ID=842506878871048
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3001/api/marketing/oauth/meta/callback
META_API_VERSION=v21.0
META_SCOPES=pages_show_list,pages_read_engagement,instagram_basic,instagram_manage_insights

# OpenAI Configuration
OPENAI_API_KEY=

# Cloudinary Configuration (File Upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Marketing Jobs Scheduler
MARKETING_JOBS_ENABLED=true
MARKETING_JOBS_HOUR=3

# Instagram Stories Collection Scheduler
# Stories expire after 24h, so collect multiple times per day
STORIES_JOBS_ENABLED=true
STORIES_JOBS_INTERVAL_HOURS=6
