{
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "SKIP_TYPE_CHECK": "true"
    }
  },
  "typescript": {
    "ignoreBuildErrors": true
  }
}
